{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "root",
    "description": "Error message tests: plain and custom-parsed enums.",
    "js2cSettings": {
        "hPrefixFile": "errors/check_error_h_prefix.inc",
        "cPrefixFile": "errors/check_error_c_prefix.inc"
    },
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "the_enum": {
            "type": "string",
            "enum": [
                "a",
                "b"
            ],
            "default": "a"
        },
        "parsed_enum": {
            "type": "string",
            "enum": [
                "a",
                "bb"
            ],
            "js2cType": "int",
            "js2cParseFunction": "error_creating_parser",
            "default": "a"
        }
    }
}
