{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "root",
    "description": "Error message tests: array length and type.",
    "js2cSettings": {
        "hPrefixFile": "errors/check_error_h_prefix.inc",
        "cPrefixFile": "errors/check_error_c_prefix.inc"
    },
    "type": "object",
    "additionalProperties": false,
    "required": [
        "the_array"
    ],
    "properties": {
        "the_array": {
            "type": "array",
            "maxItems": 3,
            "minItems": 2,
            "items": {
                "type": "integer"
            }
        },
        "name": {
            "type": "string",
            "maxLength": 8,
            "default": "abcd"
        }
    }
}
