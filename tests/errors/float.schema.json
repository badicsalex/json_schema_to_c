{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "root",
    "description": "Error message tests: floating point literals and ranges.",
    "js2cSettings": {
        "hPrefixFile": "errors/check_error_h_prefix.inc",
        "cPrefixFile": "errors/check_error_c_prefix.inc"
    },
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "fnum": {
            "type": "number",
            "default": 1337,
            "minimum": -5000,
            "maximum": 5000
        },
        "fnum2": {
            "type": "number",
            "default": 420,
            "exclusiveMinimum": -1000,
            "exclusiveMaximum": 1000
        }
    }
}
