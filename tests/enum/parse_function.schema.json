{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "root",
    "js2cSettings": {
        "cPrefixFile": "enum/parse_function_c_prefix.inc"
    },
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "color": {
            "type": "string",
            "enum": ["red", "green", "blue"],
            "js2cType": "int",
            "js2cParseFunction": "parse_color",
            "default": "green"
        }
    }
}
