{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "root",
    "type": "object",
    "additionalProperties": false,
    "required": ["value"],
    "properties": {
        "value": {
            "anyOf": [
                { "type": "integer" },
                { "type": "string", "maxLength": 8 }
            ]
        }
    }
}
